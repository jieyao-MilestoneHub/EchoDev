{
  "name": "@hey-echodev/cli",
  "version": "0.1.1",
  "description": "EchoDev — persistent design memory for Claude-assisted codebases",
  "license": "MIT",
  "homepage": "https://github.com/jieyao-MilestoneHub/EchoDev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jieyao-MilestoneHub/EchoDev.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/jieyao-MilestoneHub/EchoDev/issues",
  "keywords": [
    "claude",
    "claude-code",
    "decision-memory",
    "design-decisions",
    "adr",
    "cli"
  ],
  "type": "module",
  "bin": {
    "echodev": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "integrations",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "node -e \"const {cpSync}=require('node:fs');cpSync('../../README.md','./README.md');cpSync('../../LICENSE','./LICENSE')\" && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@hey-echodev/core": "*",
    "@hey-echodev/extractors": "*",
    "@hey-echodev/llm": "*",
    "@hey-echodev/retriever": "*",
    "@hey-echodev/storage-fs": "*",
    "tsup": "^8.5.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
